// https://github.com/pporkka/DefenderForCloudQueries/
// Prerequisites: Github organization added to Defender for Cloud as a connector
// Lists relevant information from subassessments from connected GitHub connector data. 
// Subassessments contain eg. vulnerable packages in the github projects (CATEGORY=DEPENDENCY)
// There is other categories such as "Infrastructure as Code"
// There is lots of additional data this query does not show, use the first 3 lines to get the data and then select "view details" to see the whole json, or uncomment "properties".
// REPLACE below YOURCONNECTORNAMEHERE with the name of the github connector added to your defender
securityresources
| where type == 'microsoft.security/assessments/subassessments'
| where id contains "/Microsoft.Security/securityConnectors/YOURCONNECTORNAMEHERE/devops/"
| extend category = tostring(properties.category)
| where category == "Dependency"
// | where category == "Infrastructure as Code"
| extend data = parse_json(properties.additionalData.data)
| extend target = parse_json(properties.additionalData.resourceIdAsTargetNodeId)
| extend Severity = tostring(data.Severity)
| extend Resource = tostring(target.targetResourceId)
| where isnotnull(Resource)
| extend Name=properties.displayName
| extend CVE=data.SecurityAdvisoryCVE
| extend CVSS=data.CVSSScore
| extend Identifiers=data.Identifiers
| extend Package=data.Package
| extend Ord=iif(Severity=="critical", 5, iif(Severity=="high", 4, iif(Severity=="medium", 3, iif(Severity=="low", 2,0))))
| project Resource, Severity, Name, CVE, CVSS, Identifiers, Package, Ord //,properties
| order by Ord desc
